models:
    User: { name: string, email: 'string unique', avatar_url: 'string nullable', bio: 'text nullable', location: 'string nullable comment:Ville principale (ex: Colmar)', coordinates: 'json nullable comment:{lat: ..., lng: ...}', trust_score: 'integer default:0', parent_id: 'id foreign:users nullable', is_managed: 'boolean default:false', transfer_token: 'string nullable unique', transfer_code: 'string nullable', relationships: { belongsTo: 'Parent:User:parent_id', hasMany: 'OwnedCircles:Circle, Achievement, SentMessages:Message, ReceivedMessages:Message, JoinedCircles:CircleMember, ManagedUsers:User:parent_id' } }
    Post: { user_id: id, content: text, relationships: { belongsTo: User, morphMany: 'Comment, Reaction' } }
    Comment: { user_id: id, content: text, relationships: { belongsTo: User, morphTo: Commentable, morphMany: Reaction } }
    Reaction: { user_id: id, type: string, relationships: { belongsTo: User, morphTo: Reactable } }
    Circle: { name: string, description: 'text nullable', type: 'enum:business,event,place,project', address: string, coordinates: 'json nullable', owner_id: 'id foreign:users', relationships: { belongsTo: 'Owner:User', hasMany: 'Members:CircleMember, Messages:Message' } }
    CircleMember: { circle_id: 'id foreign:circles', user_id: 'id foreign:users', role: 'enum:admin,member,guest', status: 'enum:pending,active,rejected', vouched_by_id: 'id foreign:users nullable', joined_at: timestamp, relationships: { belongsTo: 'Circle, User, Voucher:User:vouched_by_id' } }
    Skill: { name: 'string index', slug: 'string unique', category: 'string nullable', relationships: { hasMany: Achievements } }
    Achievement: { user_id: 'id foreign:users', skill_id: 'id foreign:skills', circle_id: 'id foreign:circles nullable comment:Le lieu où la compétence a été prouvée', title: string, description: 'text nullable', media_url: 'string nullable', metadata: 'json nullable comment:Prix, Durée, Détails techniques', is_verified: 'boolean default:false', relationships: { belongsTo: 'User, Skill, Circle' } }
    Message: { circle_id: 'id foreign:circles nullable comment:Contexte de la discussion', sender_id: 'id foreign:users', title: 'string nullable', content: text, type: 'enum:chat,logistics', metadata: "json nullable comment:{link_trajet: 'GoogleMaps', dispo: '5h'}", relationships: { belongsTo: 'Circle, Sender:User' } }
